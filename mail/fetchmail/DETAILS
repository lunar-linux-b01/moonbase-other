          MODULE=fetchmail
         VERSION=6.6.4
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$SFORGE_URL/$MODULE/branch_${VERSION%.*}
      SOURCE_VFY=sha256:efe01690d22bda359a579c77e2b0072658a092bff490ec0478a212c6b7d0eb70
        WEB_SITE=https://www.berlios.de/software/fetchmail/
         ENTERED=20010922
         UPDATED=20260508
           SHORT="A full-featured remote-mail retrieval and forwarding utility"

cat << EOF
Fetchmail is a remote mail retrieval and forwarding utility intended to
be used over on-demand TCP/IP links (such as SLIP or PPP connections).
It supports every remote-mail protocol now in use on the Internet:
POP2, POP3, RPOP, APOP, KPOP, all flavors of IMAP, ETRN, and ODMR. It
can even support IPv6 and IPSEC.
EOF
